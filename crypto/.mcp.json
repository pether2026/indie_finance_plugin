{
  "mcpServers": {
    "coingecko": {
      "type": "stdio",
      "command": "npx",
      "args": ["@coingecko/coingecko-mcp"],
      "env": {
        "COINGECKO_DEMO_API_KEY": "",
        "COINGECKO_ENVIRONMENT": "demo"
      }
    },
    "dune": {
      "type": "http",
      "url": "https://api.dune.com/mcp/v1",
      "headers": { "X-DUNE-API-KEY": "" }
    }
  }
}
