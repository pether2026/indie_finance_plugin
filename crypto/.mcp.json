{
  "mcpServers": {
    "coingecko": {
      "type": "stdio",
      "command": "npx",
      "args": ["@coingecko/coingecko-mcp"]
    },
    "defillama": {
      "type": "stdio",
      "command": "npx",
      "args": ["@iqai/defillama-mcp"]
    },
    "dune": {
      "type": "http",
      "url": "https://api.dune.com/mcp/v1",
      "headers": { "X-DUNE-API-KEY": "${DUNE_API_KEY}" }
    }
  }
}
