{
  "mcpServers": {
    "fred": {
      "type": "stdio",
      "command": "npx",
      "args": ["@stefanoamorelli/fred-mcp-server"],
      "env": { "FRED_API_KEY": "${FRED_API_KEY}" }
    },
    "defillama": {
      "type": "stdio",
      "command": "npx",
      "args": ["@iqai/mcp-defillama"]
    },
    "coingecko": {
      "type": "http",
      "command": "npx",
      "args": ["@coingecko/coingecko-mcp"]
    }
  }
}
